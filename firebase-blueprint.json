{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "preferredLearningStyle": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Concept": {
      "title": "Concept",
      "description": "A unique knowledge node in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "normalizedTitle": { "type": "string", "description": "Lowercase title for searching" },
        "categoryId": { "type": "string", "description": "Link to a top-level category" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "rank": { "type": "number", "description": "Global popularity score" },
        "explanationCount": { "type": "number" },
        "lastExplanation": { "type": "object", "description": "Cache of the latest generation" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "normalizedTitle", "rank", "createdAt", "updatedAt"]
    },
    "Explanation": {
      "title": "Explanation",
      "description": "A specific AI-generated cognitive structure for a concept",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conceptId": { "type": "string" },
        "userId": { "type": "string", "description": "User who triggered the generation" },
        "payload": { "type": "object", "description": "The full 3-6-9 JSON from Gemini" },
        "learningStyle": { "type": "string" },
        "votes": {
          "type": "object",
          "properties": {
            "ups": { "type": "number" },
            "downs": { "type": "number" }
          }
        },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "conceptId", "payload", "createdAt"]
    },
    "UserVaultItem": {
      "title": "User Vault Item",
      "description": "A personal link to a specific concept and explanation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "conceptId": { "type": "string" },
        "explanationId": { "type": "string" },
        "conceptTitle": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "conceptId", "explanationId", "savedAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Top-level learning categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "order"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback and bug reports",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "context": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User records"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Global learning categories"
    },
    "/concepts/{conceptId}": {
      "schema": "Concept",
      "description": "Global index of unique knowledge nodes"
    },
    "/concepts/{conceptId}/explanations/{explanationId}": {
      "schema": "Explanation",
      "description": "Variations of explanations for a specific concept"
    },
    "/users/{userId}/vault/{vaultItemId}": {
      "schema": "UserVaultItem",
      "description": "Personal saved library for a user"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Support and improvement signals"
    },
    "/global_logs/{logId}": {
      "schema": "Explanation",
      "description": "A flat view of all generations for a global discovery feed"
    }
  }
}
