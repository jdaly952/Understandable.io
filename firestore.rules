rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // 0. Catch-All Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // 1. Primitive Helpers
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // 2. Validation Blueprints
    // ===============================================================
    
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             (data.get('displayName', null) == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (data.get('photoURL', null) == null || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             data.createdAt == request.time;
    }

    function isValidUnderstandable(data) {
      return data.concept is string && data.concept.size() <= 500 &&
             data.payload is map &&
             data.createdAt == request.time &&
             (data.get('uid', null) == null || (data.uid is string && (data.uid.size() <= 128)));
    }

    function isValidVote(data) {
      return data.contentHash is string && data.contentHash.size() <= 128 &&
             data.ups is int && data.downs is int &&
             data.updatedAt == request.time;
    }

    function isValidGlobal(data) {
      return data.concept is string && data.concept.size() <= 500 &&
             data.rank is int &&
             data.lastPayload is map &&
             data.updatedAt == request.time;
    }

    function isValidCoupler(data) {
      return data.uid == request.auth.uid &&
             data.concept is string &&
             data.step is int &&
             data.content is string &&
             data.timestamp == request.time;
    }

    function isValidAxiomVault(data) {
      return data.concept is string &&
             data.step is int &&
             data.affirmationCount is int &&
             data.content is string;
    }

    // ===============================================================
    // 3. Collection Rules
    // ===============================================================

    match /axiom_vault/{axiomId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidAxiomVault(incoming());
      allow update: if isSignedIn() && isValidAxiomVault(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['affirmationCount', 'lastAffirmed']);
    }

    match /concept_couplers/{couplerId} {
      allow read, write: if isSignedIn() && (
        (request.method == 'create' && incoming().uid == request.auth.uid) ||
        (resource != null && resource.data.uid == request.auth.uid)
      );
    }

    match /_internal_/connection_test {
      allow read: if true;
    }

    match /users/{uid} {
      allow get: if isOwner(uid);
      allow create: if isOwner(uid) && isValidUser(incoming());
      allow update: if isOwner(uid) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email']);
    }

    match /saved_topics/{topicId} {
      // Identity Locked Collection
      // Handle document level get
      allow get: if isSignedIn() && existing().get('uid', null) == request.auth.uid;
      
      // Handle collection queries (list)
      // Every document in the result MUST have uid == request.auth.uid
      allow list: if isSignedIn() && resource.data.get('uid', null) == request.auth.uid;
      
      allow create: if isSignedIn() && isValidUnderstandable(incoming()) && incoming().uid == request.auth.uid;
      allow delete: if isSignedIn() && existing().get('uid', null) == request.auth.uid;
    }

    match /synthesis_logs/{logId} {
      // History of public transmutations
      allow get: if true;
      allow list: if true;
      allow create: if isValidUnderstandable(incoming());
    }

    match /global_index/{conceptId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidGlobal(incoming());
    }

    match /community_votes/{voteId} {
      allow read: if true;
      allow create: if isValidVote(incoming());
      allow update: if isValidVote(incoming());
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() && 
                    incoming().concept is string && 
                    incoming().concept.size() <= 500 &&
                    incoming().uid == request.auth.uid &&
                    incoming().createdAt == request.time;
    }
  }
}
