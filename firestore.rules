rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // 0. Catch-All Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // 1. Primitive Helpers
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // 2. Validation Blueprints
    // ===============================================================
    
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 200 &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             data.createdAt is timestamp;
    }

    function isValidAxiom(data) {
      return data.concept is string && data.concept.size() <= 500 &&
             data.payload is map &&
             data.createdAt is timestamp &&
             (data.uid == null || (data.uid is string && (data.uid == request.auth.uid || data.uid == "null")));
    }

    function isValidVote(data) {
      return data.contentHash is string && data.contentHash.size() <= 128 &&
             data.ups is int && data.downs is int &&
             data.updatedAt is timestamp;
    }

    function isValidGlobal(data) {
      return data.concept is string && data.concept.size() <= 500 &&
             data.rank is int &&
             data.lastPayload is map &&
             data.updatedAt is timestamp;
    }

    // ===============================================================
    // 3. Collection Rules
    // ===============================================================

    match /_internal_/connection_test {
      allow read: if true;
    }

    match /users/{uid} {
      allow get: if isOwner(uid);
      allow create: if isOwner(uid) && isValidUser(incoming());
      allow update: if isOwner(uid) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email']);
    }

    match /saved_axioms/{axiomId} {
      // Identity Locked Collection
      allow get: if isSignedIn() && existing().uid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && isValidAxiom(incoming()) && incoming().uid == request.auth.uid;
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
    }

    match /triangulation_logs/{logId} {
      // System History Collection
      allow create: if isValidAxiom(incoming());
      allow list: if isSignedIn() && resource.data.uid != "PRIVATE_ONLY"; // Just to force relational check if needed
      allow get: if isSignedIn();
      // More liberal list for triangulation logs as they are a public index in this app
      allow list: if isSignedIn();
    }

    match /global_index/{conceptId} {
      // Aggregate Ranking Collection
      allow read: if true;
      allow create: if isValidGlobal(incoming());
      allow update: if isValidGlobal(incoming()); // This is liberal but matches the ranking use case
    }

    match /community_votes/{voteId} {
      // Collaborative Feedback Collection
      allow read: if true;
      allow create: if isSignedIn() && isValidVote(incoming());
      allow update: if isSignedIn() && isValidVote(incoming());
    }
  }
}
