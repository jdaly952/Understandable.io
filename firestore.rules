rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // No mass listing of users
      allow create: if isOwner(userId) 
        && incoming().uid == userId 
        && incoming().email == request.auth.token.email;
      allow update: if isOwner(userId)
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'photoURL', 'preferredLearningStyle', 'lastActive']);
    }

    // --- Categories ---
    match /categories/{categoryId} {
      allow read: if true; // Publicly readable
      allow write: if false; // System only
    }

    // --- Concepts ---
    match /concepts/{conceptId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(conceptId);
      allow update: if isSignedIn() 
        && incoming().id == existing().id
        && incoming().diff(existing()).affectedKeys().hasAny(['rank', 'explanationCount', 'lastExplanation', 'updatedAt', 'tags', 'categoryId']);
        
      // --- Explanations (Subcollection) ---
      match /explanations/{explanationId} {
        allow read: if true;
        allow create: if isSignedIn() 
          && incoming().conceptId == conceptId
          && incoming().userId == request.auth.uid;
        allow update: if isSignedIn()
          && (incoming().userId == existing().userId || incoming().diff(existing()).affectedKeys().hasOnly(['votes']));
      }
    }

    // --- User Vault ---
    match /users/{userId}/vault/{itemId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().userId == userId;
      allow update: if isOwner(userId)
        && incoming().userId == userId;
      allow delete: if isOwner(userId);
    }

    // --- Feedback ---
    match /feedback/{feedbackId} {
      allow create: if true; // Allow anonymous or logged in feedback
      allow read, update, delete: if false; // Admin only (service account)
    }

    // --- Global Logs ---
    match /global_logs/{logId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
